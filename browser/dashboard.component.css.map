
      .dashboard-shell {
        padding: 24px;
        display: grid;
        gap: 24px;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        padding: 18px 22px;
        height: auto;
        border-radius: 24px;
        background: linear-gradient(135deg, #0f4c90, #1a72ca);
        color: white;
        box-shadow: var(--shadow);
      }

      .brand-lockup {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .brand-icon {
        width: 54px;
        height: 54px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: rgba(255, 255, 255, 0.18);
      }

      .eyebrow {
        font-size: 0.76rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        opacity: 0.75;
      }

      .brand-lockup h1 {
        font-size: clamp(1.25rem, 2vw, 1.8rem);
        margin-top: 4px;
      }

      .topbar-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .role-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 36px;
        padding: 0 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.14);
        color: white;
        font-weight: 700;
      }

      .user-pill {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
      }

      .summary-banner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        padding: 26px 28px;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(10px);
        box-shadow: var(--shadow);
      }

      .summary-banner h2 {
        margin-top: 6px;
        font-size: clamp(1.5rem, 2vw, 2rem);
      }

      .summary-banner p {
        margin: 8px 0 0;
        color: var(--text-muted);
        max-width: 720px;
      }

      .banner-stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(110px, 1fr));
        gap: 14px;
      }

      .banner-stats article {
        padding: 18px;
        border-radius: 20px;
        background: linear-gradient(180deg, var(--bg-soft), #ffffff);
        border: 1px solid rgba(20, 99, 183, 0.08);
        min-width: 118px;
        text-align: center;
      }

      .banner-stats strong {
        display: block;
        font-size: 1.5rem;
        font-family: var(--font-heading);
      }

      .banner-stats span {
        font-size: 0.88rem;
        color: var(--text-muted);
      }

      .loading-block {
        display: grid;
        place-items: center;
        gap: 12px;
        min-height: 260px;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.82);
        box-shadow: var(--shadow);
      }

      .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 24px;
        align-items: start;
      }

      .panel-card {
        display: flex;
        flex-direction: column;
        align-self: start;
        padding: 22px;
        border-radius: var(--card-radius);
        border: 1px solid rgba(20, 99, 183, 0.08);
        background: rgba(255, 255, 255, 0.92);
        box-shadow: var(--shadow);
      }

      .panel-header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
        margin-bottom: 20px;
      }

      .panel-header p {
        margin: 6px 0 0;
        color: var(--text-muted);
      }

      .panel-actions {
        display: flex;
        gap: 10px;
        align-items: center;
      }

      .kanban-board {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
      }

      .kanban-column {
        padding: 14px;
        border-radius: 20px;
        background: linear-gradient(180deg, rgba(20, 99, 183, 0.05), rgba(255, 255, 255, 0.9));
        border: 1px solid rgba(20, 99, 183, 0.07);
      }

      .kanban-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        font-weight: 700;
      }

      .count-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 34px;
        min-height: 34px;
        padding: 0 10px;
        border-radius: 999px;
        background: rgba(20, 99, 183, 0.1);
        color: var(--brand-dark);
        font-weight: 700;
      }

      .task-stack {
        display: grid;
        gap: 10px;
      }

      .task-card {
        padding: 14px;
        border-radius: 18px;
        background: white;
        border: 1px solid rgba(20, 99, 183, 0.08);
        box-shadow: 0 10px 18px rgba(15, 76, 144, 0.08);
        transition: transform 180ms ease, box-shadow 180ms ease;
      }

      .task-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 18px 28px rgba(15, 76, 144, 0.12);
      }

      .task-card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
      }

      .task-card h4 {
        font-size: 0.98rem;
        margin-bottom: 6px;
      }

      .task-card p {
        margin: 0;
        color: var(--text-muted);
        font-size: 0.88rem;
        line-height: 1.5;
      }

      .priority-pill {
        display: inline-flex;
        align-items: center;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 700;
      }

      .priority-high {
        background: rgba(226, 93, 93, 0.12);
        color: var(--danger);
      }

      .priority-medium {
        background: rgba(240, 163, 54, 0.14);
        color: #bb7400;
      }

      .priority-low {
        background: rgba(36, 160, 107, 0.14);
        color: var(--success);
      }

      .heatmap-wrapper {
        display: grid;
        gap: 8px;
      }

      .heatmap-row {
        display: grid;
        grid-template-columns: minmax(160px, 1.3fr) repeat(5, minmax(68px, 1fr));
        gap: 8px;
      }

      .resource-cell,
      .day-cell {
        min-height: 58px;
        border-radius: 16px;
        display: grid;
        place-items: center;
      }

      .resource-cell.label {
        justify-items: start;
        padding: 0 16px;
        background: rgba(20, 99, 183, 0.04);
      }

      .resource-cell.label span {
        font-size: 0.82rem;
        color: var(--text-muted);
      }

      .heatmap-row.header .day-cell {
        background: rgba(20, 99, 183, 0.06);
        font-weight: 700;
      }

      .heat-cell {
        color: white;
        font-weight: 700;
        box-shadow: inset 0 -10px 20px rgba(255, 255, 255, 0.08);
      }

      .metrics-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 18px;
      }

      .metric-pill {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        border-radius: 999px;
        background: rgba(20, 99, 183, 0.06);
        font-weight: 700;
      }

      .metric-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
      }

      .metric-dot.success {
        background: var(--success);
      }

      .metric-dot.warning {
        background: var(--warning);
      }

      .metric-dot.danger {
        background: var(--danger);
      }

      .distribution-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) minmax(220px, 0.8fr);
        gap: 18px;
        align-items: start;
      }

      .chart-panel,
      .mini-chart-card,
      .resource-side-list,
      .table-shell,
      .suggestions-panel,
      .comparison-table {
        border-radius: 20px;
        border: 1px solid rgba(20, 99, 183, 0.07);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(245, 250, 255, 0.94));
      }

      .chart-panel,
      .resource-side-list,
      .mini-chart-card {
        padding: 16px;
      }

      .chart-panel,
      .mini-chart-card {
        min-height: 0;
      }

      .chart-canvas {
        position: relative;
        width: 100%;
      }

      .chart-canvas--bar {
        height: 320px;
      }

      .chart-canvas--line {
        height: 180px;
      }

      .chart-canvas canvas {
        display: block;
        width: 100% !important;
        height: 100% !important;
      }

      .resource-side-list {
        display: grid;
        gap: 14px;
      }

      .mini-group h4 {
        margin-bottom: 10px;
      }

      .resource-pill {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        border-radius: 16px;
        margin-bottom: 10px;
      }

      .resource-pill.danger {
        background: rgba(226, 93, 93, 0.1);
      }

      .resource-pill.success {
        background: rgba(36, 160, 107, 0.1);
      }

      .table-shell {
        margin-top: 18px;
        overflow: hidden;
      }

      .results-table {
        width: 100%;
        background: transparent;
      }

      .results-table .mdc-data-table__row:last-child .mat-mdc-cell {
        border-bottom: none;
      }

      .result-good {
        color: var(--success);
        font-weight: 700;
      }

      .result-danger {
        color: var(--danger);
        font-weight: 700;
      }

      .result-neutral {
        color: var(--text);
        font-weight: 700;
      }

      .chart-strip {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        align-items: start;
      }

      .mini-chart-card h4 {
        margin-bottom: 12px;
      }

      .mini-chart-card {
        display: flex;
        flex-direction: column;
      }

      .chart-loading {
        display: grid;
        place-items: center;
        min-height: 220px;
        margin-bottom: 18px;
        border-radius: 20px;
        border: 1px dashed rgba(20, 99, 183, 0.14);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(245, 250, 255, 0.94));
        color: var(--text-muted);
        font-weight: 600;
      }

      .weights-form {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
        margin: 18px 0;
      }

      .suggestions-panel {
        padding: 16px 18px;
        margin-bottom: 16px;
      }

      .suggestions-panel h4 {
        margin-bottom: 10px;
      }

      .suggestions-panel ul {
        margin: 0;
        padding-left: 18px;
        color: var(--text);
      }

      .suggestions-panel li {
        margin-bottom: 10px;
        line-height: 1.55;
      }

      .empty-state {
        margin: 0;
        color: var(--text-muted);
      }

      .comparison-table {
        padding: 18px;
      }

      .comparison-header,
      .comparison-row {
        display: grid;
        grid-template-columns: 1.2fr 0.7fr 0.7fr;
        gap: 10px;
        align-items: center;
      }

      .comparison-header {
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(20, 99, 183, 0.08);
        margin-bottom: 6px;
        font-weight: 700;
      }

      .comparison-row {
        padding: 12px 0;
        border-bottom: 1px solid rgba(20, 99, 183, 0.06);
      }

      .comparison-row:last-child {
        border-bottom: none;
      }

      .comparison-row strong,
      .comparison-header strong {
        color: var(--brand);
      }

      @media (max-width: 1280px) {
        .dashboard-grid,
        .chart-strip,
        .kanban-board,
        .weights-form {
          grid-template-columns: 1fr;
        }

        .distribution-layout {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 960px) {
        .summary-banner,
        .topbar {
          flex-direction: column;
          align-items: stretch;
        }

        .banner-stats {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .dashboard-grid {
          grid-template-columns: 1fr;
        }

        .heatmap-row {
          grid-template-columns: minmax(120px, 1.2fr) repeat(5, minmax(54px, 1fr));
        }

        .comparison-header,
        .comparison-row {
          grid-template-columns: 1fr 0.65fr 0.65fr;
          font-size: 0.92rem;
        }
      }

      @media (max-width: 640px) {
        .dashboard-shell {
          padding: 16px;
        }

        .banner-stats {
          grid-template-columns: 1fr;
        }

        .topbar-actions {
          justify-content: flex-start;
        }
      }
    